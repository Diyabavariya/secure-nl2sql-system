# ============================================================
# QueryShield AI — Environment Variables Template
# ============================================================
# This file IS committed to Git. It documents all required
# environment variables WITHOUT any real values.
#
# Setup:
#   cp .env.example .env
#   Then fill in real values in .env (never commit .env).
# ============================================================

# ── Groq LLM ─────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ── JWT Authentication ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-strong-random-secret-here

# ── Database ──────────────────────────────────────────────
# Path to SQLite database file (relative to project root)
DB_PATH=database.db

# ── App ───────────────────────────────────────────────────
APP_ENV=development
