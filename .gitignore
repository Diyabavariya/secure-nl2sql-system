# ============================================================
# QueryShield AI — .gitignore
# Stack: React + Vite + Tailwind CSS + FastAPI + SQLite + Groq
# ============================================================


# ──────────────────────────────────────────────────────────────
# PYTHON ARTIFACTS
# ──────────────────────────────────────────────────────────────

# Compiled bytecode – generated automatically by the interpreter
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / packaging artifacts
*.egg-info/
dist/
build/
*.egg
MANIFEST

# Type checking caches
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Test caches and coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Virtual environments – never commit these
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter / IPython artifacts (if used for prototyping)
.ipynb_checkpoints/
*.ipynb_checkpoints


# ──────────────────────────────────────────────────────────────
# FRONTEND ARTIFACTS (React + Vite + Node)
# ──────────────────────────────────────────────────────────────

# Third-party dependencies – always regenerated from package.json
node_modules/

# Production build output – generated by `vite build` / `npm run build`
dist/
build/

# Vite internal cache
.vite/

# TypeScript build info (if TS is added later)
*.tsbuildinfo

# Optional: Storybook output
storybook-static/


# ──────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES & SECRETS
# ──────────────────────────────────────────────────────────────
# NEVER commit API keys, JWT secrets, or database credentials.
# Use a .env.example (committed) to document required variables.

.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow the safe template — it contains NO real secrets
!.env.example

# Groq API key file (if stored separately)
groq_api_key.txt
secrets/


# ──────────────────────────────────────────────────────────────
# DATABASE FILES
# ──────────────────────────────────────────────────────────────
# SQLite journal/WAL files are transient and must not be committed.
# Backup dumps should live outside the repo or in a secure store.

*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db-journal
*.db-wal
*.db-shm

# Database backup dumps
*.sql.gz
*.sql.bz2
backups/
db_backups/

# SQLite database files — binary, large, and may contain sensitive data.
# Commit an Alembic migration + seed script instead of the DB file itself.
#*.db
*.sqlite
*.sqlite3

# Large raw CSV datasets — regeneratable, not source code
# (backend/olist_*.csv files are ~65 MB combined)
*.csv


# ──────────────────────────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────────────────────────

*.log
*.log.*
logs/
log/
pip-log.txt
pip-delete-this-directory.txt


# ──────────────────────────────────────────────────────────────
# IDE & EDITOR FILES
# ──────────────────────────────────────────────────────────────

# VS Code – workspace settings are personal; share only .vscode/extensions.json
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm / WebStorm / IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim swap and backup files
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# ──────────────────────────────────────────────────────────────
# OPERATING SYSTEM FILES
# ──────────────────────────────────────────────────────────────

# macOS metadata / Finder state
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows Explorer thumbnail cache and shortcuts
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux temporary files
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ──────────────────────────────────────────────────────────────
# SECURITY & MISC
# ──────────────────────────────────────────────────────────────

# JWT signing keys stored as files (prefer env vars instead)
*.pem
*.key
*.crt
*.p12
*.pfx

# Temporary / scratch files
*.tmp
*.temp
*.bak
*.orig
.cache/
tmp/
temp/
